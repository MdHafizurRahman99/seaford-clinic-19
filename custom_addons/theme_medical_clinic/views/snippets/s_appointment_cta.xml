<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_appointment_cta" name="Book Appointment CTA">
    <section class="s_appointment_cta pt64 pb64 o_cc o_cc5"
             style="background: linear-gradient(135deg, #1A3C34 0%, #2E8B57 100%);">
        <div class="container">
            <div class="s_cta_content text-center">
                <h2 class="display-5 mb-3" style="color: white; font-weight: 800;">
                    Ready to Book Your Appointment?
                </h2>
                <p class="lead mb-4 mx-auto" style="color: rgba(255,255,255,0.85); max-width: 600px;">
