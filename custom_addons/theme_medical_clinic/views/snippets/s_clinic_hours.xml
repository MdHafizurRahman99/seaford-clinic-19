<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_clinic_hours" name="Clinic Opening Hours">
    <section class="s_clinic_hours pt64 pb64 o_cc o_cc3">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <p class="text-uppercase small fw-bold mb-2" style="color: #2E8B57; letter-spacing: 2px;">
                        VISIT US
                    </p>
                    <h2 class="h2-fs s_section_heading text-start" style="font-weight: 800; color: #1A3C34;">
                        Opening Hours
                    </h2>
                    <div class="s_hours_table mt-4">
                        <div class="s_hours_row">
                            <span class="s_day">Monday</span>
                            <span class="s_time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Tuesday</span>
                            <span class="s_time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Wednesday</span>
                            <span class="s_time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Thursday</span>
                            <span class="s_time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Friday</span>
                            <span class="s_time">8:00 AM - 6:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Saturday</span>
                            <span class="s_time">9:00 AM - 1:00 PM</span>
                        </div>
                        <div class="s_hours_row">
                            <span class="s_day">Sunday</span>
                            <span class="s_time">Closed</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="s_emergency_info mb-4">
                        <i class="fa fa-phone-square mb-2 d-block"/>
                        <h4 style="color: white; font-weight: 700;">After Hours</h4>
                        <p class="mb-1" style="color: rgba(255,255,255,0.85);">
                            For medical emergencies call <strong>000</strong>
                        </p>
                        <p class="mb-0" style="color: rgba(255,255,255,0.85);">
                            After-hours GP helpline: <strong>1800 022 222</strong>
                        </p>
                    </div>
                    <div class="bg-white rounded-3 p-4" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                        <h5 style="font-weight: 700; color: #1A3C34;">
                            <i class="fa fa-map-marker me-2" style="color: #2E8B57;"/>
                            Our Location
                        </h5>
                        <p class="text-muted mb-0">
                            Seaford, VIC 3198<br/>
                            Australia
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
