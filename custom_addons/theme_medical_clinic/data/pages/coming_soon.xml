<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_coming_soon" model="website.page">
    <field name="name">Coming Soon</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic.page_coming_soon</field>
    <field name="url">/</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic.page_coming_soon">
            <t t-call="website.layout">
                <t t-set="additional_title">Coming Soon | Seaford Central Medical Clinic</t>
                <div id="wrap" class="oe_structure clinic-coming-soon clinic-coming-soon--central">

                    <section class="clinic-coming-soon__hero clinic-coming-soon__hero--simple">
                        <div class="clinic-coming-soon__hero-media"
                             style="background-image: url('/theme_medical_clinic/static/src/img/content/hero_bg.jpg');"/>
                        <div class="container position-relative">
                            <div class="row justify-content-center">
                                <div class="col-xl-8 col-lg-9 text-center">
                                    <span class="clinic-coming-soon__eyebrow">Seaford Central Medical Clinic</span>
                                    <h1 class="clinic-coming-soon__title clinic-coming-soon__title--simple">COMING SOON</h1>
                                    <p class="clinic-coming-soon__copy clinic-coming-soon__copy--simple">
                                        Our new website is on the way.
                                    </p>
                                    <div class="clinic-coming-soon__actions">
                                        <a href="/homepage" class="btn btn-light">View Current Homepage</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
