<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_appointments" model="website.page">
    <field name="name">Appointments</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic.page_appointments</field>
    <field name="url">/appointments</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic.page_appointments">
            <t t-call="website.layout">
                <t t-set="additional_title">Appointments</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,60,52,0.92) 0%, rgba(46,139,87,0.75) 100%), url('/theme_medical_clinic/static/src/img/content/hero_bg.jpg'); background-size: cover; background-position: center;">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Book an Appointment</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.05rem; max-width: 760px; margin: 0 auto;">
                                Book online instantly or complete patient registration first if this is your first visit.
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb64" data-snippet="s_text_block" style="background-color: #F0FAF5;">
                        <div class="container">
                            <div class="row g-4 align-items-start">
                                <div class="col-lg-8">
                                    <div class="bg-white rounded-3 p-3" style="box-shadow: 0 6px 22px rgba(26,60,52,0.08); border: 1px solid rgba(46,139,87,0.16);">
                                        <iframe src="https://www.hotdoc.com.au/medical-centres/seaford-VIC-3198/seaford-central-medical-clinic/doctors?wp=w_iframe" data-hotdoc-widget="iframe" width="100%" height="800" frameBorder="0" allow="payment"/>
                                        <script async="async" src="https://cdn.hotdoc.com.au/static/assets/js/hotdoc-widgets.min.js" charset="utf-8"></script>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="rounded-3 p-4" style="background: linear-gradient(135deg, #2E8B57, #1A3C34); color: white;">
                                        <h4 style="font-weight: 700; color: white;">New Patient?</h4>
                                        <p style="color: rgba(255,255,255,0.88); line-height: 1.8;">
                                            Complete patient registration first, then return to book your appointment online.
                                        </p>
                                        <a href="https://www.hotdoc.com.au/medical-centres/signup?returnUrl=%2Fmedical-centres%2Fseaford-VIC-3198%2Fseaford-central-medical-clinic%2Fdoctors" target="_blank" rel="noopener noreferrer" class="btn" style="background-color: #FFFFFF; color: #2E8B57; border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.75rem 1.4rem;">
                                            Patient Registration
                                        </a>
                                        <hr style="border-color: rgba(255,255,255,0.22); margin: 1.2rem 0;"/>
                                        <p style="color: rgba(255,255,255,0.88); margin-bottom: 0.6rem;">
                                            Need help choosing the right appointment type?
                                        </p>
                                        <a href="tel:0397860008" class="btn" style="background-color: transparent; color: #FFFFFF; border: 2px solid rgba(255,255,255,0.7); border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.75rem 1.4rem;">
                                            Call Reception
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb64" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1A3C34;">When to call reception</h4>
                                        <ul style="color: #555; line-height: 1.85; padding-left: 1.1rem; margin-bottom: 0;">
                                            <li>Longer or complex consultations</li>
                                            <li>Mental health care plans and procedure bookings</li>
                                            <li>Difficulty finding a suitable online slot</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1A3C34;">Before your appointment</h4>
                                        <ul style="color: #555; line-height: 1.85; padding-left: 1.1rem; margin-bottom: 0;">
                                            <li>Bring Medicare and concession cards</li>
                                            <li>Bring recent results, referrals, and medication list</li>
                                            <li>Arrive early for your first visit paperwork</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
