<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_contact" model="website.page">
    <field name="name">Contact Us</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic.page_contact</field>
    <field name="url">/contact</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic.page_contact">
            <t t-call="website.layout">
                <t t-set="additional_title">Contact Us</t>
                <div id="wrap" class="oe_structure">

                    <!-- Page Banner -->
                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,60,52,0.92) 0%, rgba(46,139,87,0.75) 100%), url('/theme_medical_clinic/static/src/img/content/hero_bg.jpg'); background-size: cover; background-position: center;">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Contact Us</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">We'd love to hear from you</p>
                        </div>
                    </section>

                    <!-- Contact Details + Hours -->
                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-5">
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <div class="text-center mb-4">
                                            <i class="fa fa-map-marker d-block mb-2" style="font-size: 2rem; color: #2E8B57;"/>
                                            <h5 style="font-weight: 700; color: #1A3C34;">Our Address</h5>
                                        </div>
                                        <p class="text-muted text-center">
                                            Seaford, VIC 3198<br/>
                                            Australia
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <div class="text-center mb-4">
                                            <i class="fa fa-phone d-block mb-2" style="font-size: 2rem; color: #2E8B57;"/>
                                            <h5 style="font-weight: 700; color: #1A3C34;">Phone</h5>
                                        </div>
                                        <p class="text-muted text-center">
                                            Phone: (03) 9786 0002<br/>
                                            Fax: (03) 0000 0001
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <div class="text-center mb-4">
                                            <i class="fa fa-clock-o d-block mb-2" style="font-size: 2rem; color: #2E8B57;"/>
                                            <h5 style="font-weight: 700; color: #1A3C34;">Hours</h5>
                                        </div>
                                        <p class="text-muted text-center">
                                            Mon-Fri: 8:00 AM - 6:00 PM<br/>
                                            Saturday: 9:00 AM - 1:00 PM<br/>
                                            Sunday: Closed
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Emergency Info -->
                    <section class="pt48 pb48" data-snippet="s_text_block" style="background-color: #F0FAF5;">
                        <div class="container">
                            <div class="row justify-content-center">
                                <div class="col-lg-8">
                                    <div class="rounded-3 p-4 text-center" style="background: linear-gradient(135deg, #2E8B57, #1A3C34); color: white;">
                                        <i class="fa fa-exclamation-triangle d-block mb-2" style="font-size: 1.5rem; color: #66CDAA;"/>
                                        <h4 style="color: white; font-weight: 700;">Emergency &amp; After Hours</h4>
                                        <p style="color: rgba(255,255,255,0.85);">
                                            For medical emergencies, please call <strong>000</strong><br/>
                                            After-hours GP helpline: <strong>1800 022 222</strong>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
