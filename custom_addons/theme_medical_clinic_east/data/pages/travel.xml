<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_travel_medicine" model="website.page">
    <field name="name">Travel Medicine</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_travel_medicine</field>
    <field name="url">/travel</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_travel_medicine">
            <t t-call="website.layout">
                <t t-set="additional_title">Travel Medicine</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.6rem;">Travel Medicine</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.05rem;">
                                Destination-specific advice, vaccines, and prevention planning
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <h3 style="font-weight: 700; color: #1a4a54;">Pre-Travel Consultation Includes</h3>
                                    <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                        <li>Destination risk review and itinerary assessment</li>
                                        <li>Recommended and required travel vaccinations</li>
                                        <li>Food, water, and mosquito-borne illness prevention advice</li>
                                        <li>Travel medicine kit guidance and medication planning</li>
                                        <li>Post-travel review advice if symptoms occur</li>
                                    </ul>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Before Your Appointment</h4>
                                        <p style="color: #555; line-height: 1.8;">
                                            Please bring your itinerary, previous immunisation records, and details of current medications.
                                        </p>
                                        <p style="color: #555; line-height: 1.8;">
                                            Book at least 6 weeks before departure where possible, especially for multi-country travel.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block" style="background: #e8f4f6;">
                        <div class="container text-center">
                            <h3 style="font-weight: 800; color: #1a4a54;">Plan Early for Safer Travel</h3>
                            <p style="color: #555; max-width: 620px; margin: 0 auto 1.25rem;">
                                Travel consults are often longer appointments. Please call reception for booking support.
                            </p>
                            <a href="/appointments" class="btn btn-lg" style="background-color: #3899ac; color: white; border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.85rem 2.5rem;">
                                Book Travel Consultation
                            </a>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
