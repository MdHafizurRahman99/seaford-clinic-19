<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_patient_information" model="website.page">
    <field name="name">Patient Information</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_patient_information</field>
    <field name="url">/patient-information</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_patient_information">
            <t t-call="website.layout">
                <t t-set="additional_title">Patient Information</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Patient Information</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">
                                Everything you need before and after your visit
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">New Patient Checklist</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                            <li>Medicare card and photo ID</li>
                                            <li>Current medication list</li>
                                            <li>Relevant specialist letters or test results</li>
                                            <li>Immunisation history if available</li>
                                            <li>Arrive 10 minutes early for first appointment</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Practice Policies</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                            <li>Private billing applies unless stated otherwise</li>
                                            <li>Cancellation fees may apply for missed appointments</li>
                                            <li>Please update reception if your details change</li>
                                            <li>Zero tolerance for abusive behavior</li>
                                            <li>For emergencies, call <strong>000</strong></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb48" data-snippet="s_text_block" style="background: #e8f4f6;">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
                                        <i class="fa fa-file-text-o d-block mb-2" style="font-size: 1.8rem; color: #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Patient Forms</h5>
                                        <p style="color: #555; line-height: 1.7;">
                                            Download and complete forms before attending where possible.
                                        </p>
                                        <a href="/contact" style="color: #3899ac; font-weight: 700; text-decoration: none;">Request Forms</a>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
                                        <i class="fa fa-flask d-block mb-2" style="font-size: 1.8rem; color: #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Results &amp; Follow-up</h5>
                                        <p style="color: #555; line-height: 1.7;">
                                            Please book a review appointment for result discussion and ongoing care planning.
                                        </p>
                                        <a href="/appointments" style="color: #3899ac; font-weight: 700; text-decoration: none;">Book Follow-up</a>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.05);">
                                        <i class="fa fa-comment-o d-block mb-2" style="font-size: 1.8rem; color: #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Feedback</h5>
                                        <p style="color: #555; line-height: 1.7;">
                                            We welcome patient feedback to improve care quality and patient experience.
                                        </p>
                                        <a href="/contact" style="color: #3899ac; font-weight: 700; text-decoration: none;">Send Feedback</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Scripts and Referrals Pathway</h4>
                                        <ol style="color: #555; line-height: 1.9; padding-left: 1.2rem; margin: 0;">
                                            <li>Submit your request through reception or contact page.</li>
                                            <li>Clinical team reviews eligibility and timing since your last consult.</li>
                                            <li>If required, book a consultation before issuing documents.</li>
                                            <li>Receive update when request is ready for collection or follow-up.</li>
                                        </ol>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Hospital and Urgent Care Guidance</h4>
                                        <p style="color: #555; line-height: 1.8;">
                                            For severe chest pain, breathing difficulty, stroke symptoms, or major trauma, call <strong>000</strong> immediately.
                                        </p>
                                        <p style="color: #555; line-height: 1.8; margin-bottom: 0;">
                                            For non-urgent issues, contact reception for next available GP appointment or after-hours advice.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block">
                        <div class="container">
                            <div class="rounded-3 p-4 p-lg-5 text-center" style="background: linear-gradient(135deg, #1a4a54, #3899ac);">
                                <h3 style="color: white; font-weight: 800;">Scripts, Referrals, and Clinical Documents</h3>
                                <p style="color: rgba(255,255,255,0.85); max-width: 720px; margin: 0 auto 1.2rem;">
                                    Requests for repeat prescriptions or referrals may require a consultation, depending on your clinical needs and the time since last review.
                                </p>
                                <a href="/contact" class="btn" style="background: #ffffff; color: #3899ac; font-weight: 700; border-radius: 12px 0 12px 0; padding: 0.75rem 2rem;">
                                    Contact Reception
                                </a>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
