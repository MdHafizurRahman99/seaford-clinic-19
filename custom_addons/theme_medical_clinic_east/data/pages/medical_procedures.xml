<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_medical_procedures" model="website.page">
    <field name="name">Medical Procedures</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_medical_procedures</field>
    <field name="url">/medical-procedures</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_medical_procedures">
            <t t-call="website.layout">
                <t t-set="additional_title">Medical Procedures</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.6rem;">Medical Procedures</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.05rem;">
                                In-clinic procedures with clear planning and follow-up
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Common Procedures</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                            <li>Wound management and suturing</li>
                                            <li>Cryotherapy and skin lesion treatments</li>
                                            <li>Iron infusion appointments</li>
                                            <li>Contraceptive implant insertion/removal</li>
                                            <li>Minor procedural assessments and follow-up</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">What to Expect</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                            <li>Initial assessment and consent discussion</li>
                                            <li>Procedure suitability and risk review</li>
                                            <li>Post-procedure care instructions</li>
                                            <li>Follow-up appointment planning</li>
                                            <li>Fee advice before booking where applicable</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block" style="background: linear-gradient(135deg, #1a4a54, #3899ac);">
                        <div class="container text-center">
                            <h3 style="color: white; font-weight: 800;">Need a Procedure Booking?</h3>
                            <p style="color: rgba(255,255,255,0.85); max-width: 620px; margin: 0 auto 1.25rem;">
                                Procedure bookings often require specific appointment lengths and preparation instructions.
                            </p>
                            <a href="/appointments" class="btn btn-lg" style="background-color: #ffffff; color: #3899ac; border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.85rem 2.5rem;">
                                Contact for Procedure Booking
                            </a>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
