<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="page_admin_team" model="website.page">
    <field name="name">Admin Team</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_admin_team</field>
    <field name="url">/admin-team</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_admin_team">
            <t t-call="website.layout">
                <t t-set="additional_title">Admin Team | Seaford East Medical Clinic</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <p class="text-uppercase small fw-bold mb-2" style="color: rgba(255,255,255,0.78); letter-spacing: 2px;">Admin Team</p>
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Reception and admin support that keeps the patient journey moving</h1>
                            <p style="color: rgba(255,255,255,0.88); font-size: 1.1rem; max-width: 760px; margin: 0 auto; line-height: 1.8;">
                                The admin team at Seaford East Medical Clinic handles the practical side of care: bookings, recalls, forms, records, billing coordination, and the small steps that make the clinical side run more smoothly.
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb48" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4 justify-content-center">
                                <div class="col-lg-4 col-md-6">
                                    <div class="bg-white rounded-4 p-4 text-center h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <img alt="Manager" class="rounded-circle mb-3" src="/theme_medical_clinic_east/static/src/img/content/doctor_placeholder.png" style="width: 110px; height: 110px; object-fit: cover; border: 3px solid #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Practice Management</h5>
                                        <p style="color: #3899ac; font-size: 0.85rem; font-weight: 600;">Operations and Quality</p>
                                        <p style="color: #555; line-height: 1.7; margin: 0;">Supports clinic systems, process improvement, policy administration, and the operational side of patient service quality.</p>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <div class="bg-white rounded-4 p-4 text-center h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <img alt="Reception" class="rounded-circle mb-3" src="/theme_medical_clinic_east/static/src/img/content/doctor_placeholder.png" style="width: 110px; height: 110px; object-fit: cover; border: 3px solid #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Reception Team</h5>
                                        <p style="color: #3899ac; font-size: 0.85rem; font-weight: 600;">Patient Services</p>
                                        <p style="color: #555; line-height: 1.7; margin: 0;">Helps with appointment flow, recalls, document requests, patient enquiries, and directing people to the right clinic pathway.</p>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <div class="bg-white rounded-4 p-4 text-center h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <img alt="Admin Officer" class="rounded-circle mb-3" src="/theme_medical_clinic_east/static/src/img/content/doctor_placeholder.png" style="width: 110px; height: 110px; object-fit: cover; border: 3px solid #3899ac;"/>
                                        <h5 style="font-weight: 700; color: #1a4a54;">Administrative Support</h5>
                                        <p style="color: #3899ac; font-size: 0.85rem; font-weight: 600;">Billing and Records</p>
                                        <p style="color: #555; line-height: 1.7; margin: 0;">Supports records handling, billing workflow, form coordination, and the administrative processes patients interact with around care.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb64" data-snippet="s_text_block" style="background:#f7fbfc;">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-4 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">What the admin team can help with</h4>
                                        <ul style="padding-left: 1.2rem; line-height: 1.9; color: #555; margin: 0;">
                                            <li>Booking guidance and appointment changes</li>
                                            <li>Forms, document requests, and contact-detail updates</li>
                                            <li>General information on fees, attendance, and clinic processes</li>
                                            <li>Directing patients to the correct service page or clinical pathway</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-4 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Useful links</h4>
                                        <p style="margin: 0; line-height: 1.9;">
                                            <a href="/appointments" style="color: #3899ac; font-weight: 700; text-decoration: none;">Appointments</a><br/>
                                            <a href="/fees" style="color: #3899ac; font-weight: 700; text-decoration: none;">Fees</a><br/>
                                            <a href="/patient-information" style="color: #3899ac; font-weight: 700; text-decoration: none;">Patient Information</a><br/>
                                            <a href="/contact" style="color: #3899ac; font-weight: 700; text-decoration: none;">Contact</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
