<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_exercise_physiology" model="website.page">
    <field name="name">Exercise Physiology</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_exercise_physiology</field>
    <field name="url">/exercise-physiology</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_exercise_physiology">
            <t t-call="website.layout">
                <t t-set="additional_title">Exercise Physiology</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.6rem;">Exercise Physiology</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.05rem;">
                                Clinical exercise planning for chronic disease, recovery, and strength
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <h3 style="font-weight: 700; color: #1a4a54;">Who Can Benefit</h3>
                                    <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                        <li>Patients with diabetes, heart disease, and metabolic conditions</li>
                                        <li>Musculoskeletal pain and reduced mobility</li>
                                        <li>Post-injury and post-hospital recovery</li>
                                        <li>Falls prevention and healthy ageing support</li>
                                        <li>General deconditioning and fatigue</li>
                                    </ul>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Program Approach</h4>
                                        <p style="color: #555; line-height: 1.8;">
                                            Initial assessment, goal setting, individualized exercise plan, and regular progress review in collaboration with your GP.
                                        </p>
                                        <p style="color: #555; line-height: 1.8;">
                                            Referral pathways and rebates may be available depending on eligibility and care plan type.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
