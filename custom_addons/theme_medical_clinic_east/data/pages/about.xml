<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_about_us" model="website.page">
    <field name="name">About Us</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_about_us</field>
    <field name="url">/about-us</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_about_us">
            <t t-call="website.layout">
                <t t-set="additional_title">About Us</t>
                <div id="wrap" class="oe_structure">

                    <!-- Page Banner -->
                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%), #3899ac;">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">About Our Clinic</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">Caring for the Seaford community with dedication and expertise</p>
                            <a href="/contactus" style="color: #3899ac; text-decoration: none; font-weight: 600;">
                                <i class="fa fa-calendar me-1"/> Book An Appointment
                            </a>
                        </div>
                    </section>

                    <!-- About Content -->
                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row align-items-center g-5">
                                <div class="col-lg-6">
                                    <p class="text-uppercase small fw-bold mb-2" style="color: #3899ac; letter-spacing: 2px;">OUR STORY</p>
                                    <h2 style="font-weight: 800; color: #1a4a54;">Caring for Seaford Since Day One</h2>
                                    <div style="width: 60px; height: 3px; background: linear-gradient(90deg, #3899ac, #3899ac); border-radius: 2px; margin: 1rem 0;"/>
                                    <p style="color: #555; line-height: 1.8;">
                                        Seaford East Medical Clinic is a modern, fully equipped medical practice
                                        dedicated to providing quality healthcare to individuals and families in the
                                        Seaford community and surrounding areas.
                                    </p>
                                    <p style="color: #555; line-height: 1.8;">
                                        Our clinic features multiple consulting rooms, a treatment room, and modern
                                        diagnostic equipment. We are committed to creating a welcoming, comfortable
                                        environment where patients feel at ease.
                                    </p>
                                    <p style="color: #555; line-height: 1.8;">
                                        We pride ourselves on our patient-centred approach, taking the time to listen,
                                        understand and address your health concerns thoroughly.
                                    </p>
                                </div>
                                <div class="col-lg-6">
                                    <div class="rounded-3 overflow-hidden" style="box-shadow: 0 12px 40px rgba(56,153,172,0.15);">
                                        <img src="/theme_medical_clinic_east/static/src/img/content/hero_bg.jpg"
                                             class="img-fluid w-100" alt="Our Clinic" style="height: 400px; object-fit: cover;"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Vision, Mission, Values -->
                    <section class="pt80 pb80" data-snippet="s_text_block" style="background-color: #e8f4f6;">
                        <div class="container">
                            <div class="text-center mb-5">
                                <h2 style="font-weight: 800; color: #1a4a54;">Our Vision, Mission &amp; Values</h2>
                                <div style="width: 60px; height: 3px; background: linear-gradient(90deg, #3899ac, #3899ac); border-radius: 2px; margin: 1rem auto;"/>
                            </div>
                            <div class="row g-4">
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100 text-center" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-eye d-block mb-3" style="font-size: 2.5rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Our Vision</h4>
                                        <p style="color: #555; line-height: 1.7;">To be the leading community medical clinic in Seaford, recognised for excellence in patient care and health outcomes.</p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100 text-center" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-bullseye d-block mb-3" style="font-size: 2.5rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Our Mission</h4>
                                        <p style="color: #555; line-height: 1.7;">To promote health and wellness through excellence in clinical practice, compassionate care, and a commitment to continuous improvement.</p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100 text-center" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-heart d-block mb-3" style="font-size: 2.5rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Our Values</h4>
                                        <p style="color: #555; line-height: 1.7;">Patient-first approach, integrity, inclusivity, teamwork, and a commitment to evidence-based medicine and ethical practice.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Accreditations -->
                    <section class="pt64 pb64" data-snippet="s_text_block">
                        <div class="container text-center">
                            <p class="text-uppercase small fw-bold mb-2" style="color: #3899ac; letter-spacing: 2px;">TRUSTED &amp; ACCREDITED</p>
                            <h3 style="font-weight: 700; color: #1a4a54;">Our Affiliations</h3>
                            <div class="row justify-content-center align-items-center mt-4 g-4">
                                <div class="col-4 col-md-2"><span class="fw-bold text-muted">AGPAL</span></div>
                                <div class="col-4 col-md-2"><span class="fw-bold text-muted">RACGP</span></div>
                                <div class="col-4 col-md-2"><span class="fw-bold text-muted">AMA</span></div>
                                <div class="col-4 col-md-2"><span class="fw-bold text-muted">Medicare</span></div>
                                <div class="col-4 col-md-2"><span class="fw-bold text-muted">AHPRA</span></div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
