<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_appointments" model="website.page">
    <field name="name">Appointments</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_appointments</field>
    <field name="url">/appointments</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_appointments">
            <t t-call="website.layout">
                <t t-set="additional_title">Appointments</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(26,74,84,0.92) 0%, rgba(56,153,172,0.75) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Appointments</h1>
                            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">
                                Book the right consultation, at the right time
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb80" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-calendar-check-o d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Book Online</h4>
                                        <p style="color: #555; line-height: 1.7;">
                                            Use online booking for routine GP consultations, follow-ups, repeat care, and standard appointments.
                                        </p>
                                        <a href="/contact" class="btn" style="background: #3899ac; color: white; font-weight: 700; border-radius: 12px 0 12px 0;">
                                            Book Online
                                        </a>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-phone d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Call Reception</h4>
                                        <p style="color: #555; line-height: 1.7;">
                                            Please call for longer consultations, procedure bookings, care plans, or if you are unsure which appointment type to choose.
                                        </p>
                                        <a href="tel:0398756222" class="btn" style="background: #1a4a54; color: white; font-weight: 700; border-radius: 12px 0 12px 0;">
                                            Call (03) 9875 6222
                                        </a>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <i class="fa fa-user-plus d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">New Patients</h4>
                                        <p style="color: #555; line-height: 1.7;">
                                            New patients are welcome. Please arrive a few minutes early and bring Medicare card, photo ID, and current medication details.
                                        </p>
                                        <a href="/patient-information" class="btn" style="background: #ffffff; color: #3899ac; font-weight: 700; border: 2px solid #3899ac; border-radius: 12px 0 12px 0;">
                                            View Patient Info
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb48" data-snippet="s_text_block" style="background: #e8f4f6;">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <h3 style="font-weight: 700; color: #1a4a54;">When to Book a Longer Appointment</h3>
                                    <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem;">
                                        <li>Mental health consultations</li>
                                        <li>Care plans or chronic disease reviews</li>
                                        <li>Multiple health concerns in one visit</li>
                                        <li>Procedures or complex assessments</li>
                                        <li>New patient initial consultation</li>
                                    </ul>
                                </div>
                                <div class="col-lg-6">
                                    <h3 style="font-weight: 700; color: #1a4a54;">Cancellation Policy</h3>
                                    <p style="color: #555; line-height: 1.8;">
                                        If you cannot attend, please provide as much notice as possible so your appointment can be offered to another patient.
                                        Missed appointments and short-notice cancellations may incur a fee.
                                    </p>
                                    <a href="/fees" style="color: #3899ac; font-weight: 700; text-decoration: none;">
                                        See fees and billing policy
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb64" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Before Your Appointment</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem; margin: 0;">
                                            <li>Bring Medicare card, photo ID, and medication list.</li>
                                            <li>Arrive early if you are a new patient.</li>
                                            <li>Request a long consult for multiple concerns.</li>
                                            <li>Bring relevant referrals, reports, or specialist letters.</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Need Extra Support?</h4>
                                        <p style="color: #555; line-height: 1.8;">
                                            For procedure bookings, complex reviews, and care plans, reception can help select the right doctor and appointment length.
                                        </p>
                                        <p style="color: #555; line-height: 1.8; margin-bottom: 0;">
                                            You can also review <a href="/patient-information">patient information</a> and <a href="/fees">fees</a> before booking.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block" style="background: linear-gradient(135deg, #1a4a54, #3899ac);">
                        <div class="container text-center">
                            <h2 style="color: white; font-weight: 800;">Need Help Choosing Appointment Type?</h2>
                            <p style="color: rgba(255,255,255,0.85); max-width: 640px; margin: 0 auto 1.5rem;">
                                Our reception team can guide you to the right doctor and the right consultation length.
                            </p>
                            <a href="tel:0398756222" class="btn btn-lg" style="background-color: #ffffff; color: #3899ac; border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.85rem 2.5rem;">
                                Call Reception
                            </a>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
