<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

<record id="page_appointments" model="website.page">
    <field name="name">Appointments</field>
    <field name="is_published" eval="True"/>
    <field name="key">theme_medical_clinic_east.page_appointments</field>
    <field name="url">/appointments</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
        <t t-name="theme_medical_clinic_east.page_appointments">
            <t t-call="website.layout">
                <t t-set="additional_title">Appointments</t>
                <div id="wrap" class="oe_structure">

                    <section class="pt80 pb80" data-snippet="s_text_block"
                             style="background: linear-gradient(135deg, rgba(18,54,60,0.95) 0%, rgba(56,153,172,0.8) 100%);">
                        <div class="container text-center">
                            <h1 style="color: white; font-weight: 800; font-size: 2.8rem;">Appointments</h1>
                            <p style="color: rgba(255,255,255,0.88); font-size: 1.08rem; max-width: 760px; margin: 0 auto; line-height: 1.8;">
                                Choose the right consultation pathway for your concern. For urgent or complex issues, call reception so we can schedule the safest appointment type.
                            </p>
                        </div>
                    </section>

                    <section class="pt80 pb48" data-snippet="s_text_block">
                        <div class="container">
                            <div class="text-center" style="margin-bottom: 44px;">
                                <p class="text-uppercase" style="font-size: 0.8rem; letter-spacing: 2px; color: #3899ac; font-weight: 700; margin-bottom: 8px;">Booking Pathways</p>
                                <h2 style="font-weight: 800; color: #1a4a54; margin-bottom: 0;">How Would You Like to Book?</h2>
                            </div>
                            <div class="row g-4">
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 8px 28px rgba(20,65,75,0.08); border: 1px solid rgba(56,153,172,0.12);">
                                        <i class="fa fa-calendar-check-o d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Online Booking</h4>
                                        <p style="color: #555; line-height: 1.75;">
                                            Best for standard GP reviews, repeat care, and routine follow-up consultations.
                                        </p>
                                        <ul style="color: #555; line-height: 1.8; padding-left: 1.1rem; margin-bottom: 1rem;">
                                            <li>Routine consultations</li>
                                            <li>Repeat issues already reviewed</li>
                                            <li>General non-urgent appointments</li>
                                        </ul>
                                        <a href="#online-booking-guide" class="btn" style="background: #3899ac; color: white; font-weight: 700; border-radius: 12px 0 12px 0;">Online Booking Steps</a>
                                    </div>
                                </div>
                                <div class="col-lg-4" id="contact-reception">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 8px 28px rgba(20,65,75,0.08); border: 1px solid rgba(56,153,172,0.12);">
                                        <i class="fa fa-phone d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">Call Reception</h4>
                                        <p style="color: #555; line-height: 1.75;">
                                            Call us for long consults, procedures, mental health care plans, complex cases, and same-day urgent triage.
                                        </p>
                                        <ul style="color: #555; line-height: 1.8; padding-left: 1.1rem; margin-bottom: 1rem;">
                                            <li>Multiple concerns in one visit</li>
                                            <li>Care plans and procedural bookings</li>
                                            <li>Uncertain appointment type</li>
                                        </ul>
                                        <a href="tel:0398756222" class="btn" style="background: #1a4a54; color: white; font-weight: 700; border-radius: 12px 0 12px 0;">Call (03) 9875 6222</a>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 8px 28px rgba(20,65,75,0.08); border: 1px solid rgba(56,153,172,0.12);">
                                        <i class="fa fa-user-plus d-block mb-3" style="font-size: 2rem; color: #3899ac;"/>
                                        <h4 style="font-weight: 700; color: #1a4a54;">New Patients</h4>
                                        <p style="color: #555; line-height: 1.75;">
                                            New patients are welcome. Bring Medicare card, photo ID, medication list, and relevant reports.
                                        </p>
                                        <ul style="color: #555; line-height: 1.8; padding-left: 1.1rem; margin-bottom: 1rem;">
                                            <li>Arrive early for first visit</li>
                                            <li>Request longer consult if needed</li>
                                            <li>Bring referral/history documents</li>
                                        </ul>
                                        <a href="/patient-information" class="btn" style="background: #ffffff; color: #3899ac; font-weight: 700; border: 2px solid #3899ac; border-radius: 12px 0 12px 0;">Patient Information</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section id="online-booking-guide" class="pt48 pb48" data-snippet="s_text_block" style="background: #f7fbfc;">
                        <div class="container">
                            <div class="row g-4 align-items-stretch">
                                <div class="col-lg-7">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 4px 18px rgba(0,0,0,0.05);">
                                        <h3 style="font-weight: 700; color: #1a4a54;">Online Booking Guide</h3>
                                        <ol style="color: #555; line-height: 1.9; padding-left: 1.2rem; margin: 0;">
                                            <li>Select the appointment reason and preferred doctor.</li>
                                            <li>Choose a suitable date/time and confirm your details.</li>
                                            <li>If no suitable slot appears, call reception for manual triage support.</li>
                                        </ol>
                                        <p style="margin: 14px 0 0; color: #555; line-height: 1.75;">
                                            For telehealth, procedures, or complex reviews, reception can book a more appropriate consultation length.
                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-5">
                                    <div class="rounded-3 p-4 h-100" style="background: linear-gradient(135deg, #1a4a54, #2f8ea1); color: white;">
                                        <h4 style="color: white; font-weight: 700;">Need Help Right Now?</h4>
                                        <p style="color: rgba(255,255,255,0.88); line-height: 1.8;">
                                            If symptoms are worsening, or if you are unsure what to book, call us first for safe and timely triage.
                                        </p>
                                        <a href="tel:0398756222" class="btn" style="background: #ffffff; color: #1a4a54; font-weight: 700; border-radius: 12px 0 12px 0;">Call Reception</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt48 pb64" data-snippet="s_text_block">
                        <div class="container">
                            <div class="row g-4">
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">When to Book a Longer Appointment</h4>
                                        <ul style="color: #555; line-height: 1.9; padding-left: 1.2rem; margin: 0;">
                                            <li>Mental health consultations and care plans</li>
                                            <li>Multiple concerns in a single visit</li>
                                            <li>Complex chronic disease review</li>
                                            <li>Procedures and pre-procedure planning</li>
                                            <li>First-time consult with extensive history</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="bg-white rounded-3 p-4 h-100" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                                        <h4 style="font-weight: 700; color: #1a4a54;">Cancellation Policy</h4>
                                        <p style="color: #555; line-height: 1.8;">
                                            Please provide as much notice as possible if you cannot attend. Missed appointments and short-notice cancellations may incur a fee.
                                        </p>
                                        <p style="color: #555; line-height: 1.8; margin-bottom: 0;">
                                            Review current billing and cancellation notes before booking.
                                        </p>
                                        <a href="/fees" style="display: inline-block; margin-top: 10px; color: #3899ac; font-weight: 700; text-decoration: none;">See fees and billing policy</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt64 pb64" data-snippet="s_text_block" style="background: linear-gradient(135deg, #1a4a54, #3899ac);">
                        <div class="container text-center">
                            <h2 style="color: white; font-weight: 800;">Need Help Choosing the Right Appointment?</h2>
                            <p style="color: rgba(255,255,255,0.85); max-width: 680px; margin: 0 auto 1.5rem; line-height: 1.8;">
                                Our reception team can match your concern to the right doctor and consultation length.
                            </p>
                            <div class="d-flex justify-content-center flex-wrap" style="gap: 12px;">
                                <a href="tel:0398756222" class="btn btn-lg" style="background-color: #ffffff; color: #3899ac; border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.85rem 2.2rem;">Call Reception</a>
                                <a href="/patient-information" class="btn btn-lg" style="background: transparent; color: white; border: 2px solid rgba(255,255,255,0.7); border-radius: 14px 0 14px 0; font-weight: 700; padding: 0.85rem 2.2rem;">Prepare for Visit</a>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </t>
    </field>
</record>

</odoo>
