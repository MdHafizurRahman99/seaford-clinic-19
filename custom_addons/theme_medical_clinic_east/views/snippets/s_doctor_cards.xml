<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="s_doctor_cards" name="Doctor Team Cards">
    <section class="s_doctor_cards pt64 pb64">
        <div class="container">
            <div class="text-center mb-5">
                <p class="text-uppercase small fw-bold mb-2" style="color: #3899ac; letter-spacing: 2px;">
                    OUR TEAM
                </p>
                <h2 class="h2-fs s_section_heading" style="font-weight: 800; color: #1a4a54;">
                    Meet Our Doctors
                </h2>
                <p class="text-muted mx-auto" style="max-width: 600px;">
                    Seaford East Medical Clinic combines continuity, preventive care,
                    and practical communication across every stage of care.
                </p>
            </div>
            <div class="row g-4">
                <!-- Doctor 1 -->
                <div class="col-lg-4 col-md-6" data-name="Doctor">
                    <div class="card h-100 text-center border-0">
                        <div class="card-body pt-4 pb-4">
                            <div class="mb-3">
                                <img alt="Doctor" class="rounded-circle s_doctor_img o_editable_media"
                                     src="/web/image/theme_medical_clinic_east.img_doctor_placeholder"
                                     style="width: 130px; height: 130px; object-fit: cover; border: 4px solid #3899ac;"/>
                            </div>
                            <h3 class="h5-fs" style="font-weight: 700; color: #1a4a54;">Dr Amelia Hart</h3>
                            <p class="s_doctor_specialty mb-2">Family Medicine</p>
                            <p class="small text-muted">Continuity-focused GP care with
                            strengths in family medicine and preventive health planning.</p>
                        </div>
                    </div>
                </div>
                <!-- Doctor 2 -->
                <div class="col-lg-4 col-md-6" data-name="Doctor">
                    <div class="card h-100 text-center border-0">
                        <div class="card-body pt-4 pb-4">
                            <div class="mb-3">
                                <img alt="Doctor" class="rounded-circle s_doctor_img o_editable_media"
                                     src="/web/image/theme_medical_clinic_east.img_doctor_placeholder"
                                     style="width: 130px; height: 130px; object-fit: cover; border: 4px solid #3899ac;"/>
                            </div>
                            <h3 class="h5-fs" style="font-weight: 700; color: #1a4a54;">Dr Priya Menon</h3>
                            <p class="s_doctor_specialty mb-2">Women's Health GP</p>
                            <p class="small text-muted">Supportive care for screening,
                            family health planning, and proactive long consult reviews.</p>
                        </div>
                    </div>
                </div>
                <!-- Doctor 3 -->
                <div class="col-lg-4 col-md-6" data-name="Doctor">
                    <div class="card h-100 text-center border-0">
                        <div class="card-body pt-4 pb-4">
                            <div class="mb-3">
                                <img alt="Doctor" class="rounded-circle s_doctor_img o_editable_media"
                                     src="/web/image/theme_medical_clinic_east.img_doctor_placeholder"
                                     style="width: 130px; height: 130px; object-fit: cover; border: 4px solid #3899ac;"/>
                            </div>
                            <h3 class="h5-fs" style="font-weight: 700; color: #1a4a54;">Dr Cameron Wells</h3>
                            <p class="s_doctor_specialty mb-2">Skin and Procedure Care</p>
                            <p class="small text-muted">Focused skin checks, lesion review,
                            and minor procedure planning within a GP setting.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

</odoo>
