<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Top utility bar with phone and location (DISABLED - using custom_header.xml instead) -->
<template id="header_top_bar" inherit_id="website.layout" name="Medical Clinic Top Bar" active="False">
    <xpath expr="//header[@id='top']" position="before">
        <div class="o_top_bar d-none d-md-block" style="background-color: #1a4a54; color: rgba(255,255,255,0.85); font-size: 0.85rem; padding: 0.4rem 0;">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <i class="fa fa-map-marker me-1" style="color: #3899ac;"/> Seaford, VIC, Australia
                    </div>
                    <div class="col text-end">
                        <a href="tel:+61300000000" class="me-3" style="color: #3899ac; text-decoration: none;">
                            <i class="fa fa-phone me-1"/> (03) 0000 0000
                        </a>
                        <a href="/contact" style="color: #3899ac; text-decoration: none;">
                            <i class="fa fa-envelope me-1"/> Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </xpath>
</template>

<!-- Custom footer with clinic info (ENABLED - replaces default Odoo footer) -->
<template id="custom_footer" inherit_id="website.layout" name="Medical Clinic Footer" active="True">
    <xpath expr="//div[@id='footer']" position="replace">
        <div id="footer" class="oe_structure oe_structure_solo" t-ignore="true">
            <!-- Main Footer -->
            <section style="background-color: #1a4a54; padding: 3rem 0 1.5rem;" data-snippet="s_text_block">
                <div class="container">
                    <div class="row g-4">
                        <!-- Clinic Info -->
                        <div class="col-lg-4 col-md-6">
                            <h5 style="color: white; font-weight: 700; margin-bottom: 1rem;">Seaford East Medical Clinic</h5>
                            <p style="color: rgba(255,255,255,0.7); line-height: 1.8; font-size: 0.9rem;">
                                Providing quality healthcare to the Seaford community
                                with compassion and professionalism.
                            </p>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem; font-size: 0.9rem;">
                                    <i class="fa fa-map-marker me-2" style="color: #3899ac; width: 16px;"/>Seaford, VIC 3198, Australia
                                </li>
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem; font-size: 0.9rem;">
                                    <i class="fa fa-phone me-2" style="color: #3899ac; width: 16px;"/>(03) 9875 6222
                                </li>
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem; font-size: 0.9rem;">
                                    <i class="fa fa-envelope me-2" style="color: #3899ac; width: 16px;"/>reception@seafordmedical.com.au
                                </li>
                            </ul>
                        </div>
                        <!-- Quick Links -->
                        <div class="col-lg-2 col-md-6">
                            <h5 style="color: white; font-weight: 700; margin-bottom: 1rem;">Quick Links</h5>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li style="margin-bottom: 0.5rem;"><a href="/" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Home</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/about-us" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">About Us</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Services</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/our-team" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Our Team</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/contact" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Contact Us</a></li>
                            </ul>
                        </div>
                        <!-- Services Links -->
                        <div class="col-lg-3 col-md-6">
                            <h5 style="color: white; font-weight: 700; margin-bottom: 1rem;">Our Services</h5>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">General Practice</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Family Health</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Women's Health</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Mental Health</a></li>
                                <li style="margin-bottom: 0.5rem;"><a href="/services" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem;">Skin Cancer Checks</a></li>
                            </ul>
                        </div>
                        <!-- Opening Hours -->
                        <div class="col-lg-3 col-md-6">
                            <h5 style="color: white; font-weight: 700; margin-bottom: 1rem;">Opening Hours</h5>
                            <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem;">
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">Mon - Fri: <span style="color: #3899ac;">8:00 AM - 6:00 PM</span></li>
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">Saturday: <span style="color: #3899ac;">9:00 AM - 1:00 PM</span></li>
                                <li style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">Sunday: <span style="color: #999;">Closed</span></li>
                            </ul>
                            <div class="mt-3">
                                <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin-bottom: 0.25rem;">Emergency: <strong style="color: #3899ac;">000</strong></p>
                                <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem;">After Hours: <strong style="color: #3899ac;">1800 022 222</strong></p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Copyright Bar -->
            <section style="background-color: #142E27; padding: 1rem 0;" data-snippet="s_text_block">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin: 0;">
                                © 2026 Seaford East Medical Clinic. All rights reserved.
                            </p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <a href="#" style="color: rgba(255,255,255,0.5); font-size: 0.8rem; text-decoration: none; margin-left: 1rem;">Privacy Policy</a>
                            <a href="#" style="color: rgba(255,255,255,0.5); font-size: 0.8rem; text-decoration: none; margin-left: 1rem;">Terms of Service</a>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </xpath>
</template>


</odoo>
