<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Legacy top utility bar kept inactive; custom_header.xml owns the real header -->
<template id="header_top_bar" inherit_id="website.layout" name="Medical Clinic Top Bar" active="False">
    <xpath expr="//header[1]" position="before">
        <div class="o_top_bar d-none d-md-block" style="background-color: #1a4a54; color: rgba(255,255,255,0.85); font-size: 0.85rem; padding: 0.4rem 0;">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <i class="fa fa-map-marker me-1" style="color: #3899ac;"/> Seaford, VIC, Australia
                    </div>
                    <div class="col text-end">
                        <a href="tel:+61398756222" class="me-3" style="color: #3899ac; text-decoration: none;">
                            <i class="fa fa-phone me-1"/> (03) 9786 0002
                        </a>
                        <a href="/contact" style="color: #3899ac; text-decoration: none;">
                            <i class="fa fa-envelope me-1"/> Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </xpath>
</template>

<!-- Custom footer with clinic info (ENABLED - replaces default Odoo footer) -->
<template id="custom_footer" inherit_id="website.layout" name="Medical Clinic Footer" active="False">
    <xpath expr="//div[hasclass('o_footer_copyright')]" position="before">
        <t t-set="no_copyright" t-value="True"/>
    </xpath>
    <xpath expr="//div[@id='footer']" position="replace">
        <div id="footer" class="oe_structure oe_structure_solo clinic-footer" t-ignore="true">
            <!-- Main Footer -->
            <section class="clinic-footer-main" data-snippet="s_text_block">
                <div class="container">
                    <div class="row g-4">
                        <!-- Clinic Info -->
                        <div class="col-lg-4 col-md-6">
                            <h5 class="clinic-footer-heading">Seaford East Medical Clinic</h5>
                            <p class="clinic-footer-copy">
                                Providing quality healthcare to the Seaford community
                                with compassion and professionalism.
                            </p>
                            <ul class="clinic-footer-list">
                                <li><i class="fa fa-map-marker"/>Seaford, VIC 3198, Australia</li>
                                <li><i class="fa fa-phone"/>(03) 9786 0002</li>
                                <li><i class="fa fa-envelope"/>reception@seafordmedical.com.au</li>
                            </ul>
                        </div>
                        <!-- Quick Links -->
                        <div class="col-lg-2 col-md-6">
                            <h5 class="clinic-footer-heading">Quick Links</h5>
                            <ul class="clinic-footer-links">
                                <li><a href="/">Home</a></li>
                                <li><a href="/about-us">About Us</a></li>
                                <li><a href="/services">Services</a></li>
                                <li><a href="/our-health-team-doctors">Our Team</a></li>
                                <li><a href="/contact">Contact Us</a></li>
                            </ul>
                        </div>
                        <!-- Services Links -->
                        <div class="col-lg-3 col-md-6">
                            <h5 class="clinic-footer-heading">Our Services</h5>
                            <ul class="clinic-footer-links">
                                <li><a href="/services">General Practice</a></li>
                                <li><a href="/maternal-child-health">Family Health</a></li>
                                <li><a href="/womens-mens-health">Women's Health</a></li>
                                <li><a href="/health-wellness">Mental Health</a></li>
                                <li><a href="/skin-landing-page">Skin Cancer Checks</a></li>
                            </ul>
                        </div>
                        <!-- Opening Hours -->
                        <div class="col-lg-3 col-md-6">
                            <h5 class="clinic-footer-heading">Opening Hours</h5>
                            <ul class="clinic-footer-hours">
                                <li>Mon - Fri: <strong>8:00 AM - 6:00 PM</strong></li>
                                <li>Saturday: <strong>9:00 AM - 1:00 PM</strong></li>
                                <li>Sunday: <span>Closed</span></li>
                            </ul>
                            <div class="mt-3">
                                <p class="mb-1">Emergency: <strong>000</strong></p>
                                <p class="mb-0">After Hours: <strong>1800 022 222</strong></p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Copyright Bar -->
            <section class="clinic-footer-bottom" data-snippet="s_text_block">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <p>Copyright 2026 Seaford East Medical Clinic. All rights reserved.</p>
                        </div>
                        <div class="col-md-6">
                            <div class="clinic-footer-legal">
                                <a href="/privacy-policy">Privacy Policy</a>
                                <a href="/terms-of-service">Terms of Service</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </xpath>
</template>


</odoo>



