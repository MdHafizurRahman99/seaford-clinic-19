<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_medical_clinic_profile_list" model="ir.ui.view">
        <field name="name">medical.clinic.profile.list</field>
        <field name="model">medical.clinic.profile</field>
        <field name="arch" type="xml">
            <list string="Team Profiles" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="profile_type"/>
                <field name="qualification"/>
                <field name="availability_status"/>
                <field name="show_in_listing"/>
                <field name="is_published"/>
                <field name="slug"/>
                <field name="website_id"/>
            </list>
        </field>
    </record>

    <record id="view_medical_clinic_profile_form" model="ir.ui.view">
        <field name="name">medical.clinic.profile.form</field>
        <field name="model">medical.clinic.profile</field>
        <field name="arch" type="xml">
            <form string="Team Profile">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="profile_type"/>
                            <field name="qualification"/>
                            <field name="slug"/>
                            <field name="sequence"/>
                            <field name="website_id"/>
                        </group>
                        <group>
                            <field name="availability_status"/>
                            <field name="availability_note"/>
                            <field name="booking_url" placeholder="/appointments"/>
                            <field name="phone_fallback"/>
                            <field name="show_in_listing"/>
                            <field name="is_published"/>
                        </group>
                    </group>

                    <group>
                        <field name="image_1920" widget="image" class="oe_avatar"/>
                    </group>

                    <notebook>
                        <page string="Profile">
                            <group>
                                <field name="summary" placeholder="Short card summary..."/>
                                <field name="special_interests" placeholder="Women health, Skin checks, Chronic disease"/>
                                <field name="languages" placeholder="English, Mandarin"/>
                                <field name="bio" widget="html"/>
                            </group>
                        </page>
                        <page string="Website">
                            <group>
                                <field name="website_url" readonly="1"/>
                                <field name="booking_available" readonly="1"/>
                                <field name="availability_label" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_medical_clinic_profiles" model="ir.actions.act_window">
        <field name="name">Team Profiles</field>
        <field name="res_model">medical.clinic.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_medical_clinic_profiles"
        name="Team Profiles"
        parent="website.menu_website_global_configuration"
        action="action_medical_clinic_profiles"
        groups="website.group_website_designer,base.group_system"
        sequence="85"/>

</odoo>
