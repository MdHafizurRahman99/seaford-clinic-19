<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Custom Two-Tier Medical Clinic Header -->
<template id="custom_medical_header" inherit_id="website.layout" name="Medical Clinic Custom Header" active="False">
    <xpath expr="//header" position="replace">
        <header id="medical-clinic-header" class="medical-clinic-header">
            <!-- Top Info Bar -->
            <div class="header-top-bar o_top_bar">
                <div class="container-fluid px-4">
                    <div class="row align-items-center">
                        <!-- Social Icons - Left -->
                        <div class="col-auto d-none d-md-block">
                            <div class="social-icons">
                                <a href="https://facebook.com" target="_blank" aria-label="Facebook" class="me-2">
                                    <i class="fa fa-facebook"/>
                                </a>
                                <a href="https://instagram.com" target="_blank" aria-label="Instagram">
                                    <i class="fa fa-instagram"/>
                                </a>
                            </div>
                        </div>
                        
                        <!-- Contact - Right -->
                        <div class="col text-md-end">
                            <div class="top-quick-links">
                                <a href="tel:0397860002" class="top-contact">
                                    <i class="fa fa-phone me-1"/>
                                    <span class="d-none d-lg-inline">(03) 9786 0002</span>
                                </a>
                                <a href="mailto:hello@seafordeastmedical.com.au" class="top-contact">
                                    <i class="fa fa-envelope me-1"/>
                                    <span class="d-none d-lg-inline">hello@seafordeastmedical.com.au</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Main Navigation Bar -->
            <nav class="navbar navbar-expand-lg header-main-bar" data-name="Custom Header">
                <div class="container-fluid px-4">
                    <!-- Logo & Brand -->
                    <a href="/" class="navbar-brand d-flex align-items-center text-decoration-none" data-name="Brand">
                        <img src="/theme_medical_clinic_east/static/src/img/logo-seaford-east.svg" class="logo-mark me-2" alt="Seaford East Medical Clinic logo"/>
                        <div class="brand-text">
                            <span class="brand-name">SEAFORD EAST MEDICAL CLINIC</span>
                        </div>
                    </a>
                    
                    <!-- Mobile Toggle Button -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" 
                            data-bs-target="#medicalMainMenu" aria-controls="medicalMainMenu" 
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    
                    <!-- Main Menu -->
                    <div class="collapse navbar-collapse" id="medicalMainMenu" data-name="Main Menu">
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                            <!-- About Us with Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="/about-us" id="aboutUsDropdown" 
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    About Us
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="aboutUsDropdown">
                                    <li><a class="dropdown-item" href="/about-us">Philosophy</a></li>
                                    <li><a class="dropdown-item" href="/patient-information">Patient Information</a></li>
                                    <li><a class="dropdown-item" href="/fees">Fees</a></li>
                                    <li><a class="dropdown-item" href="/patient-links">Patient Links</a></li>
                                    <li><a class="dropdown-item" href="/mymedicare-info">MyMedicare</a></li>
                                    <li><a class="dropdown-item" href="/covid-19-information">COVID-19 Information</a></li>
                                    <li><a class="dropdown-item" href="/privacy-policy">Privacy Policy</a></li>
                                    <li><a class="dropdown-item" href="/terms-of-service">Terms of Service</a></li>
                                </ul>
                            </li>
                            
                            <!-- Doctors (Flat) -->
                            <li class="nav-item">
                                <a href="/our-health-team-doctors" class="nav-link">Doctors</a>
                            </li>
                            
                            <!-- Services with Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="/services" id="servicesDropdown" 
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Services
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="servicesDropdown">
                                    <li><a class="dropdown-item" href="/telehealth">Telehealth</a></li>
                                    <li><a class="dropdown-item" href="/womens-health">Women's Health</a></li>
                                    <li><a class="dropdown-item" href="/mens-health">Men's Health</a></li>
                                    <li><a class="dropdown-item" href="/childrens-health">Children's Health</a></li>
                                    <li><a class="dropdown-item" href="/chronic-disease-management">Chronic Disease Management</a></li>
                                    <li><a class="dropdown-item" href="/preventative-health">Preventative Health</a></li>
                                    <li><a class="dropdown-item" href="/immunisations">Immunisations</a></li>
                                    <li><a class="dropdown-item" href="/travel">Travel Medicine</a></li>
                                    <li><a class="dropdown-item" href="/corporate-flu-clinics">Corporate Flu Clinics</a></li>
                                    <li><a class="dropdown-item" href="/iron-infusions">Iron Infusions</a></li>
                                    <li><a class="dropdown-item" href="/shingles-vaccine">Shingles Vaccine</a></li>
                                    <li><a class="dropdown-item" href="/contraceptive-implant">Contraceptive Implant</a></li>
                                    <li><a class="dropdown-item" href="/fertility-support-family-planning">Fertility Support + Family Planning</a></li>
                                    <li><a class="dropdown-item" href="/skin-landing-page">Skin Checks</a></li>
                                    <li><a class="dropdown-item" href="/sexual-health">Sexual Health</a></li>
                                    <li><a class="dropdown-item" href="/antenatal-care">Antenatal Care</a></li>
                                    <li><a class="dropdown-item" href="/pregnancy-breastfeeding">Pregnancy &amp; Breastfeeding</a></li>
                                </ul>
                            </li>
                            
                            <!-- Allied Health (Flat) -->
                            <li class="nav-item">
                                <a href="/our-health-team-allied-health" class="nav-link">Allied Health</a>
                            </li>
                            
                            <!-- News (Flat) -->
                            <li class="nav-item">
                                <a href="/newsletter" class="nav-link">News</a>
                            </li>
                            
                            <!-- GP Vacancies (Flat) -->
                            <li class="nav-item">
                                <a href="/career" class="nav-link">GP Vacancies</a>
                            </li>
                            
                            <!-- Contact (Flat) -->
                            <li class="nav-item">
                                <a href="/contact" class="nav-link">Contact</a>
                            </li>
                        </ul>
                        
                        <!-- Book Online Button -->
                        <a href="/appointments" class="btn btn-book-online" data-name="Book Online Button">
                            <i class="fa fa-calendar-check-o me-1"/>
                            <span>Book Online</span>
                        </a>
                    </div>
                </div>
            </nav>
        </header>
    </xpath>
</template>

</odoo>
